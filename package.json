{
  "name": "infrastructure",
  "version": "1.0.0",
  "description": "Central hub for cross-project infrastructure, shared packages, tools, and documentation.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "lint:shell": "bash -n scripts/*.sh agents/lib/*.sh",
    "test:registry": "node scripts/validate-registry.mjs",
    "test:agent-learning:esm": "npm --prefix packages/agent-learning run build && node scripts/validate-agent-learning-esm.mjs",
    "test:cc": "npx tsx --test scripts/cc/commands/__tests__/*.test.ts scripts/cc/lib/__tests__/*.test.ts",
    "build:cc": "node scripts/cc/build-bundle.mjs",
    "test": "npm run lint:shell && npm run test:registry && npm run test:agent-learning:esm && npm run test:cc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clayparrish-cyber/infrastructure.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/clayparrish-cyber/infrastructure/issues"
  },
  "homepage": "https://github.com/clayparrish-cyber/infrastructure#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0"
  }
}
